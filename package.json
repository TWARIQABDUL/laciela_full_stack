{
  "name": "lacaselo-project",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently \"npm start --workspace=backend\" \"npm start --workspace=frontend\"",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm start --workspace=frontend\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0"
  }
}
